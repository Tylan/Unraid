<?xml version="1.0"?>
<Container version="2">
  <Name>Haven</Name>
  <Repository>ghcr.io/ancsemi/haven:latest</Repository>
  <Registry>https://github.com/ancsemi/Haven</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/198511-support-tylan-haven/</Support>
  <Project>https://github.com/ancsemi/Haven</Project>
  <ReadMe/>
  <Overview>Haven is a self-hosted Discord alternative. Run it on your machine. Invite friends with a code. No cloud. No email signup. No tracking. Free forever.</Overview>
  <Category>Productivity: Network:Voip Network:Messenger</Category>
  <WebUI>https://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Tylan/Unraid/master/templates/Haven.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Tylan/Unraid/master/img/Haven.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DonateText>If you like an app, please donate to the respective developers; I'm just writing XML files over here. But if you have some change to spare afterwards, maybe chuck me a buck?</DonateText>
  <DonateLink>https://buymeacoffee.com/mctylan</DonateLink>
  <Requires/>
  <Config Name="Web Port" Target="PORT" Default="3000" Mode="" Description="Default HTTPS port.  Redirect HTTP-&amp;gt;HTTPS is PORT+1 (i.e. 3001 if Web Port is 3000)" Type="Variable" Display="always" Required="true" Mask="false">3000</Config>
  <Config Name="Appdata" Target="/data" Default="/mnt/user/appdata/haven" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/haven</Config>
  <Config Name="SERVER_NAME" Target="SERVER_NAME" Default="" Mode="" Description="Name shown in the UI" Type="Variable" Display="always" Required="true" Mask="false">My Haven</Config>
  <Config Name="ADMIN_USERNAME" Target="ADMIN_USERNAME" Default="" Mode="" Description="First account to register becomes admin" Type="Variable" Display="always" Required="true" Mask="false">admin</Config>
  <Config Name="GIPHY_API_KEY" Target="GIPHY_API_KEY" Default="" Mode="" Description="Optional: enable GIF search" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="VAPID_EMAIL" Target="VAPID_EMAIL" Default="" Mode="" Description="Optional: email for push notifications" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="TURN_URL" Target="TURN_URL" Default="" Mode="" Description="Optional: TURN relay for voice over internet (turn:your-server:3478)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Host Key 8" Target="TURN_SECRET" Default="" Mode="" Description="Shared secret (coturn --use-auth-secret)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="" Type="Variable" Display="advanced-hide" Required="true" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="" Type="Variable" Display="advanced-hide" Required="true" Mask="false">100</Config>
  <Config Name="TailScale Fallback State Directory" Target="CA_TS_FALLBACK_DIR" Default="/app/backend/data" Mode="{3}" Description="Fallback container directory for tailscale state information - Added By Community Applications" Type="Variable" Display="advanced" Required="{7}" Mask="{8}">/data</Config>
  <TailscaleStateDir/>
</Container>
